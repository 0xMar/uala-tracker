NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Secret shared between Next.js and the Python extraction API
EXTRACT_API_SECRET=<random-secret>

# Required for /api/ingest (Make automation)
# Found in Supabase Dashboard → Settings → API Keys (secret key)
SUPABASE_SECRET_KEY=<secret-key>

# HMAC secret for API key hashing (generate with: openssl rand -hex 32)
API_KEY_HMAC_SECRET=<random-hex-32>

# Optional: override the auth email redirect URL in local development.
# Defaults to http://localhost:3000/auth/callback if not set.
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
